import { Button, LineEdit, ListView, Palette } from "std-widgets.slint";
import { TabBase } from "tab_base.slint";
import { AppStateSlint, AppStateCallbacks } from "../appstate.slint";
import { ToggleSelector } from "../widgets/toggle-selector.slint";

export global SetupCallbacks {
    in property <[string]> recent-files;
    callback language-changed(bool);
    callback theme-changed(bool);
    callback file-browser(create-new: bool);
    callback setup-next-button() -> string;
}

export component ProjectSetup inherits TabBase {
    in-out property <AppStateSlint> data;
    callback reset-to-here();

    VerticalLayout {
        padding-left: 40px;
        spacing: 10px;
        HorizontalLayout {
            padding-top: 20px;
            spacing: 10px;
            Text {
                text: @tr("Project File Path:");
                vertical-alignment: center;
            }

            TextInput {
                y: 0;
                text: data.save-file-path;
                read-only: true;
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        HorizontalLayout {
            spacing: 4px;
            Button {
                text: @tr("Open File");
                horizontal-stretch: 1;
                clicked => {
                    reset-to-here();
                    SetupCallbacks.file-browser(false)
                }
            }

            Button {
                text: @tr("New Project");
                horizontal-stretch: 1;
                clicked => {
                    reset-to-here();
                    SetupCallbacks.file-browser(true)
                }
            }

            Rectangle {
                horizontal-stretch: 8;
            }
        }

        Text {
            text: "\nRecent Projects";
        }

        HorizontalLayout {
            Rectangle {
                background: Palette.alternate-background;
                border-radius: 4px;
                border-width: 1px;
                border-color: Palette.border;
                ListView {
                    for entry in SetupCallbacks.recent-files: Rectangle {
                        background: data.save-file-path == entry ? Palette.selection-background : touch.has-hover ? Palette.control-background.darker(0.8) : Palette.control-background;
                        border-width: 1px;
                        border-color: Palette.border;
                        height: 20px;
                        Text {
                            text: entry;
                            color: data.save-file-path == entry ? whitesmoke : Palette.foreground;
                        }

                        FocusScope {
                            focus-gained(reason) => {
                                parent.border-color = Palette.foreground;
                            }
                            focus-lost(reason) => {
                                parent.border-color = Palette.border;
                            }
                            focus-on-tab-navigation: true;
                            accessible-role: switch;
                            accessible-label: entry;
                            capture-key-pressed(event) => {
                                if (event.text == " " || event.text == "\n") {
                                    touch.clicked();
                                    return EventResult.accept;
                                } else {
                                    return EventResult.reject;
                                }
                            }
                        }

                        touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                reset-to-here();
                                data.save-file-path = entry;
                                AppStateCallbacks.sync-appstate(data);
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 40px;
            }
        }

        // Next button and language toggle
        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            padding: 8px;
            height: 48px;
            spacing: 20px;

            ToggleSelector {
                width: 80px;
                left-title: "EN";
                right-title: "FR";
                toggle-active: data.french-selected;
                toggled(fr) => {
                    data.french-selected = fr;
                    SetupCallbacks.language-changed(fr)
                }
            }

            ToggleSelector {
                width: 80px;
                left-title: "🌞";
                right-title: "🌙";
                toggle-active: data.dark-selected;
                toggled(dark) => {
                    data.dark-selected = dark;
                    Palette.color-scheme = dark ? ColorScheme.dark : ColorScheme.light;
                    SetupCallbacks.theme-changed(dark)
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            msg := Text {
                color: red;
                wrap: TextWrap.word-wrap;
                max-width: 400px;
            }

            btn := Button {
                text: @tr("Load and Continue");
                enabled: !data.save-file-path.is-empty;

                clicked => {
                    let result = SetupCallbacks.setup-next-button();
                    if (result == "yay") {
                        root.next()
                    } else {
                        msg.text = @tr("Cannot continue: {}", result);
                        msg.visible = true;
                    }
                }
            }
        }
    }
}
