export enum TableColumnTypeSlint {
    Unset,
    Numerical,
    Categorical
}

export struct TableColumnSlint {
    title: string,
    column_type: TableColumnTypeSlint,
    column_entries: [string],
    enabled: bool
}

export struct TableDataSlint { columns: [TableColumnSlint], excluded_rows: [int], number_rows: int}

